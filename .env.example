# Frontend API base (optional; defaults to same origin in production)
# VITE_API_URL=http://localhost:3001

# Optional third-party keys used by the app when configured
# VITE_RAPIDAPI_KEY=

# Supabase (PR1+): anon key only; never put the service role key in Vite
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
#
# Auth (PR3): in Supabase Dashboard → Authentication → URL configuration, add
# the site URL and redirect allow list, e.g. http://localhost:5173/auth/update-password
